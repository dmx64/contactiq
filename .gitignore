# ContactIQ .gitignore
# Comprehensive ignore file for backend + mobile app

# ============================================================================
# BACKEND (Python/Flask)
# ============================================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Virtual environments
backend/venv/
backend/.venv/
backend/env/
backend/ENV/
backend/env.bak/
backend/venv.bak/

# Flask
backend/instance/
backend/.webassets-cache

# Database
backend/*.db
backend/*.sqlite
backend/*.sqlite3
backend/contactiq.db

# Environment variables
backend/.env
backend/.env.local
backend/.env.development
backend/.env.production

# Logs
backend/*.log
backend/logs/
*.log

# ============================================================================
# MOBILE APP (React Native/Expo)
# ============================================================================

# Expo
mobile/.expo/
mobile/dist/
mobile/npm-debug.*
mobile/*.jks
mobile/*.p8
mobile/*.p12
mobile/*.key
mobile/*.mobileprovision
mobile/*.orig.*
mobile/web-build/

# Node.js
mobile/node_modules/
mobile/npm-debug.log*
mobile/yarn-debug.log*
mobile/yarn-error.log*

# React Native
mobile/.bundle/
mobile/.gradle/
mobile/android/app/build/
mobile/android/.gradle/
mobile/android/captures/
mobile/android/gradle.properties
mobile/android/keystore.properties
mobile/android/local.properties
mobile/android/app/src/main/assets/fonts/
mobile/android/app/src/main/res/drawable-*/

# iOS
mobile/ios/build/
mobile/ios/DerivedData/
mobile/ios/*.xcworkspace/xcuserdata
mobile/ios/*.xcodeproj/xcuserdata
mobile/ios/Pods/
mobile/ios/Podfile.lock

# macOS
mobile/.DS_Store
mobile/ios/.DS_Store

# Metro
mobile/.metro-health-check*

# Testing
mobile/coverage/

# Environment
mobile/.env
mobile/.env.local
mobile/.env.development
mobile/.env.production

