# ContactIQ — Environment Variables
# Copy to .env and fill in your values

# Server
SECRET_KEY=change-me-to-random-string
DB_PATH=contactiq.db

# Free API keys (optional — get for better enrichment)
GITHUB_TOKEN=ghp_your_github_token
GNEWS_API_KEY=your_gnews_key          # https://gnews.io
GUARDIAN_API_KEY=your_guardian_key      # https://open-platform.theguardian.com/access/

# Optional paid/research keys
OPENCORPORATES_API_KEY=               # https://opencorporates.com/api_accounts/new
OPENSANCTIONS_URL=                    # self-hosted yente URL or leave empty
OPENSANCTIONS_API_KEY=                # https://opensanctions.org
