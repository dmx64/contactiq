# ContactIQ — Environment Variables
# Copy to .env and fill in your values

# Server
SECRET_KEY=change-me-to-random-string
DB_PATH=contactiq.db

# Free API keys (optional — get for better enrichment)
GITHUB_TOKEN=ghp_your_github_token
GNEWS_API_KEY=your_gnews_key          # https://gnews.io
GUARDIAN_API_KEY=your_guardian_key      # https://open-platform.theguardian.com/access/

# Optional paid/research keys
OPENCORPORATES_API_KEY=               # https://opencorporates.com/api_accounts/new
OPENSANCTIONS_URL=                    # self-hosted yente URL or leave empty
OPENSANCTIONS_API_KEY=                # https://opensanctions.org

# LinkedIn Provider (12th API provider — choose one or both)
# Option A: Self-hosted via linkedin-api (free, 80 req/hr, requires LinkedIn account)
LINKEDIN_EMAIL=your-linkedin-scraping-account@example.com
LINKEDIN_PASSWORD=your-password
LINKEDIN_RATE_LIMIT=80                # requests per hour
LINKEDIN_DELAY=3.0                    # seconds between requests
LINKEDIN_CACHE_TTL=604800             # 7 days

# Option B: ScrapIn API fallback (paid, unlimited, no account needed)
SCRAPIN_API_KEY=your-scrapin-key      # https://scrapin.io
