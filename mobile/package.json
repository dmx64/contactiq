{
  "name": "contactiq-mobile",
  "version": "1.0.0",
  "description": "ContactIQ Mobile - Contact Intelligence Platform",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "start:dev": "expo start --dev-client",
    "start:tunnel": "expo start --tunnel",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "build:all": "eas build --platform all",
    "submit:android": "eas submit --platform android",
    "submit:ios": "eas submit --platform ios",
    "update": "eas update",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "prebuild": "expo prebuild",
    "install:pods": "cd ios && pod install"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.0",
    "@react-native-async-storage/async-storage": "~1.23.0",
    "@react-navigation/bottom-tabs": "^6.5.0",
    "@react-navigation/native": "^6.1.0",
    "@react-navigation/stack": "^6.3.0",
    "expo": "~50.0.0",
    "expo-av": "~13.10.0",
    "expo-barcode-scanner": "~12.9.0",
    "expo-camera": "~14.1.0",
    "expo-contacts": "~12.8.0",
    "expo-device": "~5.9.0",
    "expo-file-system": "~16.0.0",
    "expo-font": "~11.10.0",
    "expo-haptics": "~12.8.0",
    "expo-image": "~1.10.0",
    "expo-image-picker": "~14.7.0",
    "expo-linear-gradient": "~12.7.0",
    "expo-local-authentication": "~13.8.0",
    "expo-notifications": "~0.27.0",
    "expo-print": "~12.8.0",
    "expo-secure-store": "~12.9.0",
    "expo-sharing": "~11.10.0",
    "expo-splash-screen": "~0.26.0",
    "expo-status-bar": "~1.11.0",
    "react": "18.2.0",
    "react-native": "0.73.0",
    "react-native-gesture-handler": "~2.14.0",
    "react-native-qrcode-svg": "^6.3.0",
    "react-native-reanimated": "~3.6.0",
    "react-native-safe-area-context": "4.8.2",
    "react-native-screens": "~3.29.0",
    "react-native-svg": "14.1.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@eslint/js": "^8.57.0",
    "@types/jest": "^29.5.0",
    "@types/react": "~18.2.0",
    "@types/react-native": "~0.73.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.57.0",
    "eslint-config-expo": "^7.0.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-native": "^4.1.0",
    "jest": "^29.5.0",
    "metro-react-native-babel-preset": "^0.77.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "contactiq",
    "contact-intelligence",
    "osint",
    "caller-id",
    "react-native",
    "expo",
    "mobile-app"
  ],
  "author": "ContactIQ Team",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dmx64/contactiq/issues"
  },
  "homepage": "https://github.com/dmx64/contactiq#readme",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "expo": {
    "install": {
      "exclude": [
        "react-native-safe-area-context"
      ]
    }
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg)"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ]
  },
  "private": true
}
